{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["esnext", "dom"],
		"jsx": "react-jsx",
		"module": "ESNext",
		"rootDir": ".",
		"moduleResolution": "bundler",
		"baseUrl": "./src",
		"paths": {
			"@components/*": ["components/*"],
			"@hooks/*": ["hooks/*"],
			"@pages/*": ["pages/*"],
			"@settings/*": ["settings/*"],
			"@api/*": ["api/*"],
			"@commonTypes/*": ["types/*"],
			"@store/*": ["store/*"],
			"@booking/*": ["booking/*"]
		},
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitReturns": true,
		"skipLibCheck": true
	},
	"include": ["src", "src/types", "./jest.setup.ts"],
	"exclude": ["node_modules", "./.build"]
}
